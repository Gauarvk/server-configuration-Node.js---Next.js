// create a middleware folder inside this add uploadToCloudinary.js
//  /middleware/uploadToCloudinary.js
//  if your file get base64 Image then it will work
const cloudinary = require('./../utils/cloudinary');

async function uploadBase64(base64, folder) {
  if (!base64) return null;

  const result = await cloudinary.uploader.upload(base64, {
    folder,
    resource_type: "image",
  });

  return result.secure_url;
}

exports.uploadStoreImages = async (req, res, next) => {
  try {
    if (req.body.storeLogo?.startsWith("data:image")) {
      const logoUrl = await uploadBase64(req.body.storeLogo, "stores");
      req.body.storeLogo = logoUrl;
    }

    if (req.body.cashbackImage?.startsWith("data:image")) {
      const cashbackUrl = await uploadBase64(
        req.body.cashbackImage,
        "cashback"
      );
      req.body.cashbackImage = cashbackUrl;
    }

    next();
  } catch (err) {
    next(err);
  }
};

